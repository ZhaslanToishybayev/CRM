# ===========================================
# 🔐 SECURITY NOTICE
# ===========================================
# This file contains placeholder values for local development.
# NEVER commit real API keys and secrets to version control!
# For production, use environment variables or secure vault.
# ===========================================

# Environment
ENVIRONMENT=development

# Supabase Configuration
# Get these from your Supabase project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# AI Integration (GLM 4.6+)
# Get API key from Z.AI platform
ZAI_API_KEY=your_zai_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here

# Additional API Keys (Optional)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# API Configuration
API_TIMEOUT=60000
CACHE_DURATION=1800
MAX_RETRIES=3

# Feature Flags
ENABLE_AI_SUGGESTIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
DEMO_MODE=false
AI_DEMO_MODE=false

# MongoDB (Alternative Database)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=gamified_tasks

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# ===========================================
# SETUP INSTRUCTIONS
# ===========================================
# 1. Replace placeholder values with real credentials
# 2. Copy .env.development content for local testing
# 3. For production, use environment variables
# 4. Run with defines (recommended for Flutter Web):
# flutter run -d web-server \
#   --dart-define=SUPABASE_URL=... \
#   --dart-define=SUPABASE_ANON_KEY=... \
#   --dart-define=ZAI_API_KEY=... \
#   --dart-define=MINIMAX_API_KEY=...
# ===========================================
